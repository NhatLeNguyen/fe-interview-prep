# ============================================================
# Supabase — lấy tại Dashboard > Settings > API Keys
# ============================================================
# Project URL (công khai)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Publishable key (sb_publishable_...) — công khai, an toàn để lộ ở client (đã có RLS bảo vệ)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# Secret key (sb_secret_...) — tương đương service_role, BYPASS RLS.
# ⚠️ CHỈ dùng server-side. KHÔNG commit. KHÔNG prefix NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxx

# ============================================================
# URL gốc TIN CẬY của app — dùng cho link xác nhận email (chống host-header injection).
# Dev: http://localhost:3000 · Production: https://<domain-vercel>
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
